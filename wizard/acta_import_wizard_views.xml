<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_construction_import_wizard_form" model="ir.ui.view">
        <field name="name">construction.contractor.import.wizard.form</field>
        <field name="model">construction.contractor.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar actas desde CSV">
                <group>
                    <field name="file_name"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="create_missing"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
