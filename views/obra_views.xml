<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_construction_site_tree" model="ir.ui.view">
        <field name="name">construction.site.tree</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_name"/>
                <field name="city"/>
                <field name="supervisor_user_id"/>
                <field name="record_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_site_form" model="ir.ui.view">
        <field name="name">construction.site.form</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_records" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="record_count" string="Actas" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="partner_name"/>
                            <field name="city"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="supervisor_user_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_construction_site_search" model="ir.ui.view">
        <field name="name">construction.site.search</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="partner_name"/>
                <field name="city"/>
                <filter name="filter_active" string="Activas" domain="[('active', '=', True)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_city" string="Ciudad" context="{'group_by': 'city'}"/>
                    <filter name="group_supervisor" string="Supervisor" context="{'group_by': 'supervisor_user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_construction_site" model="ir.actions.act_window">
        <field name="name">Obras</field>
        <field name="res_model">construction.site</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_construction_site_search"/>
    </record>
</odoo>
